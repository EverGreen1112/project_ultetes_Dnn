@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<IEnumerable<Ultetes.Dnn.Project_Ultetes_Dnn.Models.ProductTypeViewModel>>
@using System.Linq
@using System.Collections.Generic

<div class="project-ultetes-container">
    @* GOMBSOR *@
    <div class="category-buttons" style="margin-bottom: 20px;">
        <button type="button" class="nav-btn active" onclick="switchTab('Zoldseg', this)" style="padding: 10px 20px; cursor: pointer; border: 1px solid #ccc; background: #eee;">Zöldség vetőmag</button>
        <button type="button" class="nav-btn" onclick="switchTab('Virag', this)" style="padding: 10px 20px; cursor: pointer; border: 1px solid #ccc; background: #eee;">Virág vetőmag</button>
        <button type="button" class="nav-btn" onclick="switchTab('Hagyma', this)" style="padding: 10px 20px; cursor: pointer; border: 1px solid #ccc; background: #eee;">Hagymák, gumók</button>
    </div>

    @{
        var monthColors = ViewBag.MonthColors as Dictionary<string, int[]>;
        string[] groupKeys = { "Zoldseg", "Virag", "Hagyma" };
    }

    @foreach (var key in groupKeys)
    {
        @* Minden kategóriának saját táblázat-tárolója van. Alapból csak a Zoldseg látszik. *@
        <div id="tab-@key" class="tab-content" style="@(key == "Zoldseg" ? "" : "display:none;")">
            <table style="width: 100%; border-collapse: collapse;" border="1">
                <thead>
                    <tr style="background-color: #f2f2f2; text-align: center;">
                        <th style="text-align: left; padding: 8px; width: 30%;">Típus (@key)</th>
                        <th>Jan</th>
                        <th>Feb</th>
                        <th>Már</th>
                        <th>Ápr</th>
                        <th>Máj</th>
                        <th>Jún</th>
                        <th>Júl</th>
                        <th>Aug</th>
                        <th>Sze</th>
                        <th>Okt</th>
                        <th>Nov</th>
                        <th>Dec</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var groupData = Model.Where(x => x.CategoryGroup == key).GroupBy(x => x.ProductTypeName).ToList();
                    }
                    @foreach (var group in groupData)
                    {
                        <tr>
                            <td style="padding: 5px;">
                                <select style="width: 100%; padding: 6px; font-size: 14px;">
                                    <option value="" selected>@group.Key (@group.Count() db)</option>
                                    @foreach (var p in group)
                                    {
                                        <option>-- @p.ProductName</option>
                                    }
                                </select>
                            </td>
                            @{ int[] months = monthColors.ContainsKey(group.Key) ? monthColors[group.Key] : new int[12]; }
                            @for (int i = 0; i < 12; i++)
                            {
                                string bgColor = "transparent";

                                if (months[i] == 1) { bgColor = "#f39c12"; }
                                else if (months[i] == 2) { bgColor = "#3498db"; }
                                else if (months[i] == 3) { bgColor = "#2ecc71"; }

                                <td style="background-color: @bgColor; height: 40px; min-width: 35px;"></td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @* JELMAGYARÁZAT *@
    <div style="margin-top: 15px; font-size: 14px;">
        <strong>Jelmagyarázat:</strong>
        <span style="display:inline-block; width:15px; height:15px; background-color:#f39c12; margin-left:15px; vertical-align: middle;"></span> Vetés
        <span style="display:inline-block; width:15px; height:15px; background-color:#3498db; margin-left:15px; vertical-align: middle;"></span> Aratás
        <span style="display:inline-block; width:15px; height:15px; background-color:#2ecc71; margin-left:15px; vertical-align: middle;"></span> Mindkettő
    </div>

    @* VÁLTÓ SCRIPT *@
    <script type="text/javascript">
        function switchTab(tabId, btn) {
            // Összes tábla elrejtése
            document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
            // Választott tábla megjelenítése
            document.getElementById('tab-' + tabId).style.display = 'block';

            // Gombok stílusának frissítése
            document.querySelectorAll('.nav-btn').forEach(b => {
                b.style.background = '#eee';
                b.style.fontWeight = 'normal';
            });
            btn.style.background = '#ccc';
            btn.style.fontWeight = 'bold';
        }
    </script>
</div>