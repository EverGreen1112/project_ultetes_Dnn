@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<IEnumerable<Ultetes.Dnn.Project_Ultetes_Dnn.Models.ProductTypeViewModel>>
@using System.Linq
@using System.Collections.Generic

<div class="project-ultetes-container">
    @* GOMBSOR *@
    <div class="ultetes-category-buttons" style="margin-bottom: 20px;">
        <button type="button" class="ultetes-nav-btn active" onclick="switchTab('Zoldseg', this)" style="padding: 10px 20px; cursor: pointer; border: 1px solid #ccc; background: #eee;">Zöldség vetőmag</button>
        <button type="button" class="ultetes-nav-btn" onclick="switchTab('Virag', this)" style="padding: 10px 20px; cursor: pointer; border: 1px solid #ccc; background: #eee;">Virág vetőmag</button>
        <button type="button" class="ultetes-nav-btn" onclick="switchTab('Hagyma', this)" style="padding: 10px 20px; cursor: pointer; border: 1px solid #ccc; background: #eee;">Hagymák, gumók</button>
    </div>

    @{
        var monthColors = ViewBag.MonthColors as Dictionary<string, int[]>;
        string[] groupKeys = { "Zoldseg", "Virag", "Hagyma" };
    }

    @foreach (var key in groupKeys)
    {
        <div id="tab-@key" class="ultetes-tab-content" style='@(key == "Zoldseg" ? "" : "display:none;")'>
            <table class="ultetes-calendar-table" style="width: 100%; border-collapse: collapse;" border="1">
                <thead>
                    <tr class="ultetes-table-header" style="background-color: #f2f2f2; text-align: center;">
                        <th class="ultetes-type-col" style="text-align: left; padding: 8px; width: 35%;">Típus (@key)</th>
                        <th class="ultetes-month-col">Jan</th>
                        <th class="ultetes-month-col">Feb</th>
                        <th class="ultetes-month-col">Már</th>
                        <th class="ultetes-month-col">Ápr</th>
                        <th class="ultetes-month-col">Máj</th>
                        <th class="ultetes-month-col">Jún</th>
                        <th class="ultetes-month-col">Júl</th>
                        <th class="ultetes-month-col">Aug</th>
                        <th class="ultetes-month-col">Sze</th>
                        <th class="ultetes-month-col">Okt</th>
                        <th class="ultetes-month-col">Nov</th>
                        <th class="ultetes-month-col">Dec</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var groupData = Model.Where(x => x.CategoryGroup == key).GroupBy(x => x.ProductTypeName).ToList();
                    }
                    @foreach (var group in groupData)
                    {
                        <tr>
                            <td class="ultetes-control-cell" style="padding: 5px;">
                                <div class="ultetes-control-wrapper" style="display: flex; align-items: center; gap: 8px;">

                                    @* A Gomb *@
                                    <div class="ultetes-btn-wrapper" style="width: 32px; height: 32px; flex-shrink: 0;">
                                        <a class="ultetes-product-link" href="#" target="_blank" title="Ugrás a termékoldalra"
                                           style="visibility: hidden; display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; background-color: #3498db; color: white; text-decoration: none; border-radius: 4px; font-weight: bold;">
                                            🔎
                                        </a>
                                    </div>

                                    @* A Select Box *@
                                    <select class="ultetes-select" style="flex-grow: 1; padding: 6px; font-size: 14px; cursor: pointer;" onchange="updateProductLink(this)">
                                        <option value="" selected>@group.Key (@group.Count() db)</option>
                                        @foreach (var p in group)
                                        {
                                            <option value="@p.UrlSlug">-- @p.ProductName</option>
                                        }
                                    </select>

                                </div>
                            </td>
                            @{ int[] months = monthColors.ContainsKey(group.Key) ? monthColors[group.Key] : new int[12]; }
                            @for (int i = 0; i < 12; i++)
                            {
                                string bgColor = "transparent";
                                string statusClass = "status-ures";

                                if (months[i] == 1) { bgColor = "#f39c12"; statusClass = "status-vetes"; }
                                else if (months[i] == 2) { bgColor = "#3498db"; statusClass = "status-aratas"; }
                                else if (months[i] == 3) { bgColor = "#2ecc71"; statusClass = "status-mindketto"; }

                                <td class="ultetes-calendar-cell @statusClass" style="background-color: @bgColor; height: 40px; min-width: 35px;"></td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @* JELMAGYARÁZAT *@
    <div class="ultetes-legend" style="margin-top: 15px; font-size: 14px;">
        <strong class="ultetes-legend-title">Jelmagyarázat:</strong>
        <span class="ultetes-legend-item"><span class="ultetes-legend-color status-vetes" style="display:inline-block; width:15px; height:15px; background-color:#f39c12; margin-left:15px; vertical-align: middle;"></span> Vetés</span>
        <span class="ultetes-legend-item"><span class="ultetes-legend-color status-aratas" style="display:inline-block; width:15px; height:15px; background-color:#3498db; margin-left:15px; vertical-align: middle;"></span> Aratás</span>
        <span class="ultetes-legend-item"><span class="ultetes-legend-color status-mindketto" style="display:inline-block; width:15px; height:15px; background-color:#2ecc71; margin-left:15px; vertical-align: middle;"></span> Mindkettő</span>
    </div>

    @* JAVASCRIPT A VÁLTÁSHOZ ÉS A GOMBHOZ *@
    <script type="text/javascript">
        function switchTab(tabId, btn) {
            document.querySelectorAll('.ultetes-tab-content').forEach(function (t) { t.style.display = 'none'; });
            document.getElementById('tab-' + tabId).style.display = 'block';

            document.querySelectorAll('.ultetes-nav-btn').forEach(function (b) {
                b.style.background = '#eee';
                b.style.fontWeight = 'normal';
                b.classList.remove('active');
            });
            btn.style.background = '#ccc';
            btn.style.fontWeight = 'bold';
            btn.classList.add('active');
        }

        function updateProductLink(selectElem) {
            var btn = selectElem.parentElement.querySelector('.ultetes-product-link');
            var selectedSlug = selectElem.value;

            if (selectedSlug) {
                btn.href = "/Részletek/" + selectedSlug;
                btn.style.visibility = "visible";
            } else {
                btn.style.visibility = "hidden";
            }
        }
    </script>
</div>